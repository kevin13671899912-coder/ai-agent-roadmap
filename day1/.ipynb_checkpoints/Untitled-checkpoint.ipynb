   "cell_type": "raw",
   "id": "8bf7b974-da68-4777-94e8-dbcc421e51e5",
   "metadata": {},
   "source": [
    "import os\n",
    "import sys\n",
    "from openai import OpenAI\n",
    "\n",
    "# =====================================================================\n",
    "# 步骤 1: 初始化客户端\n",
    "# 此时会自动从你在 PowerShell 中配好的 Windows 环境变量中读取 Key 和 URL\n",
    "# =====================================================================\n",
    "deepseek_client = OpenAI(\n",
    "    api_key=os.environ.get(\"DEEPSEEK_API_KEY\"),\n",
    "    base_url=os.environ.get(\"DEEPSEEK_BASE_URL\")\n",
    ")\n",
    "\n",
    "# =====================================================================\n",
    "# 步骤 2: 定义 Tool 函数（普通的 Python 函数）\n",
    "# =====================================================================\n",
    "def query_employee(name: str) -> str:\n",
    "    \"\"\"模拟查询公司内部员工信息的本地工具\"\"\"\n",
    "    # 模拟一个简单的员工数据库\n",
    "    employee_db = {\n",
    "        \"张三\": {\"department\": \"核心研发部\", \"title\": \"后端架构师\"},\n",
    "        \"李四\": {\"department\": \"视觉设计部\", \"title\": \"高级UI设计师\"}\n",
    "    }\n",
    "    \n",
    "    employee = employee_db.get(name)\n",
    "    if employee:\n",
    "        return f\"{name}的部门是{employee['department']}，职位是{employee['title']}。\"\n",
    "    return f\"未找到名为 '{name}' 的员工信息。\"\n",
    "\n",
    "# =====================================================================\n",
    "# 步骤 3: 模拟用户提问 -> 手动调用 Tool -> 喂给 LLM -> 流式输出自然语言\n",
    "# =====================================================================\n",
    "# 1. 用户的原始问题\n",
    "user_query = \"张三在我们公司是干嘛的？\"\n",
    "print(f\"【用户提问】: {user_query}\")\n",
    "\n",
    "# 2. 手动调用 Tool 函数获取死板的原始数据\n",
    "tool_result = query_employee(\"张三\")\n",
    "print(f\"--> [后台日志] Tool 运行结果: {tool_result}\\n\")\n",
    "\n",
    "# 3. 组织消息结构（将 Tool 的结果作为系统上下文传给模型）\n",
    "messages = [\n",
    "    {\n",
    "        \"role\": \"system\", \n",
    "        \"content\": \"你是一个贴心的企业内部HR助手。请根据后台提供的数据，自然、热情地回答用户的问题，不要生搬硬套原始格式。\"\n",
    "    },\n",
    "    {\"role\": \"user\", \"content\": user_query},\n",
    "    {\"role\": \"system\", \"content\": f\"后台数据库最新查询结果：{tool_result}\"}\n",
    "]\n",
    "\n",
    "# 4. 调用 DeepSeek 并开启流式输出 (stream=True)\n",
    "print(\"【HR助手流式回复】: \", end=\"\")\n",
    "try:\n",
    "    response_stream = deepseek_client.chat.completions.create(\n",
    "        model=\"deepseek-v4-flash\",  # 填入你使用的具体模型名称\n",
    "        messages=messages,\n",
    "        stream=True                 # 开启流式（打字机效果）\n",
    "    )\n",
    "    \n",
    "    # 5. 在 Jupyter 中实时刷新并打印每一个字块\n",
    "    for chunk in response_stream:\n",
    "        if chunk.choices[0].delta.content is not None:\n",
    "            # flush=True 确保文字立刻吐在 Jupyter 屏幕上，而不是等全部生成完才一起显示\n",
    "            print(chunk.choices[0].delta.content, end=\"\", flush=True)\n",
    "    print() # 打印完毕后换行\n",
    "    \n",
    "except Exception as e:\n",
    "    print(f\"\\n\\n❌ 出错啦！请检查环境变量是否生效或网络是否通畅。\")\n",
    "    print(f\"错误原因: {e}\")"
   ]
  },
